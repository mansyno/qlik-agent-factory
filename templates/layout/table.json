{
    "qInfo": {
        "qType": "table"
    },
    "qExtendsId": "",
    "qMetaDef": {
        "title": "{{TITLE}}"
    },
    "qHyperCubeDef": {
        "qDimensions": [
            {{#each resolvedDimensions}}
            {
                "qLibraryId": "{{id}}",
                "qNullSuppression": true,
                "qDef": {
                    "cId": "{{cid}}",
                    "autoSort": true,
                    "qSortCriterias": [
                        {
                            "qSortByNumeric": 1,
                            "qSortByAscii": 1,
                            "qSortByLoadOrder": 1
                        }
                    ],
                    "textAlign": {
                        "auto": true,
                        "align": "left"
                    },
                    "representation": {
                        "type": "text"
                    }
                }
            }{{#unless @last}},{{/unless}}
            {{/each}}
        ],
        "qMeasures": [
            {{#each resolvedMeasures}}
            {
                "qLibraryId": "{{id}}",
                "qDef": {
                    "cId": "{{cid}}",
                    "autoSort": true,
                    "textAlign": {
                        "auto": true,
                        "align": "left"
                    },
                    "representation": {
                        "type": "text"
                    }
                },
                "qSortBy": {
                    "qSortByNumeric": -1,
                    "qSortByLoadOrder": 1
                }
            }{{#unless @last}},{{/unless}}
            {{/each}}
        ],
        "qSuppressZero": false,
        "qSuppressMissing": true,
        "qInterColumnSortOrder": {{{qInterColumnSortOrder}}},
        "qColumnOrder": {{{qColumnOrder}}},
        "columnOrder": {{{qColumnOrder}}},
        "columnWidths": {{{columnWidths}}}
    },
    "columnOrder": {{{qColumnOrder}}},
    "columnWidths": {{{columnWidths}}},
    "showTitles": true,
    "title": "{{TITLE}}",
    "subtitle": "",
    "footnote": "",
    "disableNavMenu": false,
    "showDetails": true,
    "showDetailsExpression": false,
    "search": {
        "sorting": "auto"
    },
    "totals": {
        "show": true,
        "position": "noTotals",
        "label": "Totals"
    },
    "scrolling": {
        "horizontal": true,
        "keepFirstColumnInView": false,
        "keepFirstColumnInViewTouch": false
    },
    "multiline": {
        "wrapTextInHeaders": true,
        "wrapTextInCells": true
    },
    "visualization": "table",
    "version": "1.0.0"
}