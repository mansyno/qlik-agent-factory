{
    "name": "qlik-architect-agent",
    "version": "2.0.0",
    "description": "Qlik Agent Factory — Architect + Enhancer agents with UI Command Center",
    "main": "index.js",
    "scripts": {
        "start": "concurrently --names \"SERVER,UI\" --prefix-colors \"cyan,magenta\" \"node server.js\" \"npm run dev --prefix ui\"",
